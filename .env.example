# --- Banco (Postgres) ---
# Neon, Supabase, ou qualquer Postgres. Use a connection string com sslmode=require.
# Sem isso, o painel roda em modo MOCK (dados de exemplo) e a ingestão é desabilitada.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Fundamentos (Financial Modeling Prep) ---
# Free tier: 250 req/dia. https://site.financialmodelingprep.com/developer/docs
# Sem isso, a ingestão grava preço/ATH e deixa os fundamentos nulos.
FMP_API_KEY=""

# --- Proteção do endpoint de ingestão ---
# Qualquer string secreta. O Vercel Cron envia "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=""
